router.get("/", async (req, res) => {
  const { id } = req.params;
  const order = await orderController.getById(id);
  return res.status(200).json({ message: "Order retrieved" });
});

router.post("/", async (req, res) => {
  const { id } = req.params;
  const order = await orderController.createOrder(id);
  return res.status(201).json({ message: "Order created" });
});

router.delete("/id", async (req, res) => {
  const { id } = req.params;
  await orderController.deleteOrder(id);
  return res.status(204).send();
});

module.exports = router;

3. pvz.js
const express = require("express");
const router = express.Router();
const db = require("../db/db");

router.get("/", (req, res, next) => {
  try {
    const pvz = db.prepare("SELECT * FROM pvz ORDER BY city, address").all();
    res.json(pvz);
  } catch (err) {
    next(err);
  }
});

module.exports = router;

